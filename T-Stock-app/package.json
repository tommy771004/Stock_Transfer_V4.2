{
  "name": "t-stock-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "sync-web": "bash scripts/build-mobile.sh",
    "sync-and-ios": "bash scripts/build-mobile.sh --ios",
    "sync-and-android": "bash scripts/build-mobile.sh --android",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~52.0.46",
    "expo-asset": "~11.0.4",
    "expo-file-system": "~18.0.12",
    "expo-haptics": "~14.0.1",
    "expo-router": "~4.0.20",
    "expo-splash-screen": "~0.29.22",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.6",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-webview": "^13.12.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "typescript": "^5.3.3"
  }
}
